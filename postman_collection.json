        {
          "name": "Get All Employees (with Pagination & Filters)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:3000/api/employees?page=1&limit=10&search=john&department=dept_id&jobTitle=Developer",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "employees"],
              "query": [
                {
                  "key": "page",
                  "value": "1",
                  "description": "Page number for pagination"
                },
                {
                  "key": "limit",
                  "value": "10",
                  "description": "Items per page"
                },
                {
                  "key": "search",
                  "value": "john",
                  "description": "Search by name or email"
                },
                {
                  "key": "department",
                  "value": "dept_id",
                  "description": "Filter by department ID"
                },
                {
                  "key": "jobTitle",
                  "value": "Developer",
                  "description": "Filter by job title"
                }
              ]
            }
