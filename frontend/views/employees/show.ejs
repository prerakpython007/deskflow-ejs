<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= employee.firstName %> <%= employee.lastName %> | OfficeMS</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.3.0/fonts/remixicon.css" rel="stylesheet"/>
    <style>
        body {
            background: linear-gradient(135deg, #0f0f1e 0%, #1a1a2e 100%);
        }
        .glass-card {
            background: rgba(30, 30, 46, 0.7);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.08);
        }
        .info-card {
            background: rgba(20, 20, 35, 0.6);
            border: 1px solid rgba(255, 255, 255, 0.05);
        }
        .subordinate-card {
            background: rgba(20, 20, 35, 0.6);
            border: 1px solid rgba(255, 255, 255, 0.05);
            transition: all 0.3s ease;
        }
        .subordinate-card:hover {
            border-color: rgba(99, 102, 241, 0.3);
            transform: translateX(5px);
        }
    </style>
</head>
<body class="min-h-screen">
    <nav class="border-b border-gray-800 bg-black/30 backdrop-blur-md sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16">
                <div class="flex items-center">
                    <div class="flex items-center gap-2">
                        <div class="w-8 h-8 bg-gradient-to-br from-indigo-500 to-purple-600 rounded-lg flex items-center justify-center">
                            <i class="ri-building-line text-white text-sm"></i>
                        </div>
                        <h1 class="text-xl font-bold bg-gradient-to-r from-indigo-400 to-purple-400 bg-clip-text text-transparent">OfficeMS</h1>
                    </div>
                    <div class="hidden sm:flex sm:ml-10 space-x-1">
                        <a href="/departments" class="px-4 py-2 rounded-lg text-sm font-medium text-gray-400 hover:text-white hover:bg-white/5 transition-all">
                            <i class="ri-layout-grid-line mr-2"></i>Departments
                        </a>
                        <a href="/employees" class="px-4 py-2 rounded-lg text-sm font-medium text-gray-400 hover:text-white hover:bg-white/5 transition-all">
                            <i class="ri-team-line mr-2"></i>Employees
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </nav>
    
    <main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            <div class="lg:col-span-1">
                <div class="glass-card rounded-2xl overflow-hidden sticky top-20">
                    <div class="p-6 text-center border-b border-gray-800">
                        <div class="w-24 h-24 bg-gradient-to-br from-indigo-500 to-purple-600 rounded-full flex items-center justify-center mx-auto mb-4">
                            <i class="ri-user-3-line text-white text-4xl"></i>
                        </div>
                        <h2 class="text-xl font-bold text-white"><%= employee.firstName %> <%= employee.lastName %></h2>
                        <p class="text-indigo-400 text-sm mt-1"><%= employee.jobTitle %></p>
                        <div class="mt-3">
                            <span class="px-3 py-1 bg-green-500/20 text-green-400 rounded-full text-xs">
                                <%= employee.isActive ? 'Active' : 'Inactive' %>
                            </span>
                        </div>
                    </div>
                    
                    <div class="p-6 space-y-4">
                        <div class="info-card rounded-xl p-3">
                            <div class="flex items-center gap-3 text-gray-400 text-sm">
                                <i class="ri-mail-line text-indigo-400"></i>
                                <span><%= employee.email %></span>
                            </div>
                        </div>
                        <% if (employee.phone) { %>
                        <div class="info-card rounded-xl p-3">
                            <div class="flex items-center gap-3 text-gray-400 text-sm">
                                <i class="ri-phone-line text-indigo-400"></i>
                                <span><%= employee.phone %></span>
                            </div>
                        </div>
                        <% } %>
                        <div class="info-card rounded-xl p-3">
                            <div class="flex items-center gap-3 text-gray-400 text-sm">
                                <i class="ri-building-line text-indigo-400"></i>
                                <span><%= employee.department ? employee.department.name : 'N/A' %></span>
                            </div>
                        </div>
                        <% if (employee.supervisor) { %>
                        <div class="info-card rounded-xl p-3">
                            <div class="flex items-center gap-3 text-gray-400 text-sm">
                                <i class="ri-user-star-line text-indigo-400"></i>
                                <span>Reports to: <%= employee.supervisor.firstName %> <%= employee.supervisor.lastName %></span>
                            </div>
                        </div>
                        <% } %>
                        <% if (employee.salary) { %>
                        <div class="info-card rounded-xl p-3">
                            <div class="flex items-center gap-3 text-gray-400 text-sm">
                                <i class="ri-money-dollar-circle-line text-indigo-400"></i>
                                <span>Salary: $<%= employee.salary.toLocaleString() %></span>
                            </div>
                        </div>
                        <% } %>
                        <% if (employee.dateOfBirth) { %>
                        <div class="info-card rounded-xl p-3">
                            <div class="flex items-center gap-3 text-gray-400 text-sm">
                                <i class="ri-cake-line text-indigo-400"></i>
                                <span>Birth: <%= new Date(employee.dateOfBirth).toLocaleDateString() %></span>
                            </div>
                        </div>
                        <% } %>
                        <div class="info-card rounded-xl p-3">
                            <div class="flex items-center gap-3 text-gray-400 text-sm">
                                <i class="ri-calendar-line text-indigo-400"></i>
                                <span>Joined: <%= new Date(employee.joinDate).toLocaleDateString() %></span>
                            </div>
                        </div>
                    </div>
                    
                    <div class="p-6 border-t border-gray-800 flex gap-3">
                        <a href="/employees/<%= employee._id %>/edit" class="flex-1 px-4 py-2 bg-indigo-500/20 text-indigo-400 rounded-xl hover:bg-indigo-500/30 transition-all text-center">
                            <i class="ri-edit-line mr-1"></i> Edit
                        </a>
                        <a href="/employees" class="flex-1 px-4 py-2 bg-gray-700/50 text-gray-300 rounded-xl hover:bg-gray-700/70 transition-all text-center">
                            <i class="ri-arrow-left-line mr-1"></i> Back
                        </a>
                    </div>
                </div>
            </div>
            
            <div class="lg:col-span-2">
                <% if (employee.address) { %>
                <div class="glass-card rounded-2xl p-6 mb-6">
                    <div class="flex items-center gap-3 mb-4">
                        <i class="ri-map-pin-line text-indigo-400 text-xl"></i>
                        <h3 class="text-lg font-semibold text-white">Address</h3>
                    </div>
                    <p class="text-gray-300"><%= employee.address %></p>
                    <% if (employee.city || employee.state || employee.country) { %>
                        <p class="text-gray-400 text-sm mt-2">
                            <%= employee.city || '' %> <%= employee.city && employee.state ? ', ' : '' %> <%= employee.state || '' %> <%= employee.state && employee.country ? ', ' : '' %> <%= employee.country || '' %>
                        </p>
                    <% } %>
                </div>
                <% } %>
                
                <div class="glass-card rounded-2xl overflow-hidden">
                    <div class="px-6 py-5 border-b border-gray-800">
                        <div class="flex items-center gap-3">
                            <i class="ri-team-line text-indigo-400 text-xl"></i>
                            <h3 class="text-lg font-semibold text-white">Team Members Reporting</h3>
                            <span class="px-2 py-1 bg-indigo-500/20 text-indigo-400 rounded-lg text-xs"><%= subordinates.length %> subordinates</span>
                        </div>
                    </div>
                    
                    <div class="p-6">
                        <% if (subordinates.length === 0) { %>
                            <div class="text-center py-8">
                                <div class="w-16 h-16 bg-gray-800 rounded-full flex items-center justify-center mx-auto mb-3">
                                    <i class="ri-user-line text-2xl text-gray-600"></i>
                                </div>
                                <p class="text-gray-400">No team members reporting to this employee</p>
                            </div>
                        <% } else { %>
                            <div class="grid gap-3">
                                <% subordinates.forEach(function(sub) { %>
                                <div class="subordinate-card rounded-xl p-4">
                                    <div class="flex items-center justify-between">
                                        <div class="flex items-center gap-3">
                                            <div class="w-10 h-10 bg-gradient-to-br from-indigo-500/20 to-purple-500/20 rounded-xl flex items-center justify-center">
                                                <i class="ri-user-3-line text-indigo-400"></i>
                                            </div>
                                            <div>
                                                <a href="/employees/<%= sub._id %>" class="font-medium text-white hover:text-indigo-400 transition">
                                                    <%= sub.firstName %> <%= sub.lastName %>
                                                </a>
                                                <p class="text-xs text-gray-400 mt-1"><%= sub.jobTitle %></p>
                                            </div>
                                        </div>
                                        <span class="text-xs text-gray-500"><%= sub.department ? sub.department.name : 'N/A' %></span>
                                    </div>
                                </div>
                                <% }); %>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </main>
</body>
</html>