<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= department.name %> | OfficeMS</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.3.0/fonts/remixicon.css" rel="stylesheet"/>
    <style>
        body {
            background: linear-gradient(135deg, #0f0f1e 0%, #1a1a2e 100%);
        }
        .glass-card {
            background: rgba(30, 30, 46, 0.7);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.08);
        }
        .employee-card {
            background: rgba(20, 20, 35, 0.6);
            border: 1px solid rgba(255, 255, 255, 0.05);
            transition: all 0.3s ease;
        }
        .employee-card:hover {
            border-color: rgba(99, 102, 241, 0.3);
            transform: translateX(5px);
        }
    </style>
</head>
<body class="min-h-screen">
    <nav class="border-b border-gray-800 bg-black/30 backdrop-blur-md sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16">
                <div class="flex items-center">
                    <div class="flex items-center gap-2">
                        <div class="w-8 h-8 bg-gradient-to-br from-indigo-500 to-purple-600 rounded-lg flex items-center justify-center">
                            <i class="ri-building-line text-white text-sm"></i>
                        </div>
                        <h1 class="text-xl font-bold bg-gradient-to-r from-indigo-400 to-purple-400 bg-clip-text text-transparent">OfficeMS</h1>
                    </div>
                    <div class="hidden sm:flex sm:ml-10 space-x-1">
                        <a href="/departments" class="px-4 py-2 rounded-lg text-sm font-medium text-gray-400 hover:text-white hover:bg-white/5 transition-all">
                            <i class="ri-layout-grid-line mr-2"></i>Departments
                        </a>
                        <a href="/employees" class="px-4 py-2 rounded-lg text-sm font-medium text-gray-400 hover:text-white hover:bg-white/5 transition-all">
                            <i class="ri-team-line mr-2"></i>Employees
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </nav>
    
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <div class="glass-card rounded-2xl overflow-hidden">
            <div class="px-6 py-5 border-b border-gray-800 flex justify-between items-center">
                <div class="flex items-center gap-4">
                    <div class="w-12 h-12 bg-gradient-to-br from-indigo-500 to-purple-600 rounded-xl flex items-center justify-center">
                        <i class="ri-folder-5-line text-white text-xl"></i>
                    </div>
                    <div>
                        <h2 class="text-xl font-semibold text-white"><%= department.name %></h2>
                        <p class="text-sm text-gray-400 mt-1"><%= department.description || 'No description provided' %></p>
                    </div>
                </div>
                <div class="flex gap-2">
                    <a href="/departments/<%= department._id %>/edit" class="px-4 py-2 bg-indigo-500/20 text-indigo-400 rounded-xl hover:bg-indigo-500/30 transition-all text-sm flex items-center gap-2">
                        <i class="ri-edit-line"></i> Edit
                    </a>
                    <a href="/departments" class="px-4 py-2 bg-gray-700/50 text-gray-300 rounded-xl hover:bg-gray-700/70 transition-all text-sm flex items-center gap-2">
                        <i class="ri-arrow-left-line"></i> Back
                    </a>
                </div>
            </div>
            
            <div class="p-6">
                <div class="flex items-center gap-3 mb-6">
                    <i class="ri-team-line text-indigo-400 text-xl"></i>
                    <h3 class="text-lg font-semibold text-white">Team Members</h3>
                    <span class="px-2 py-1 bg-indigo-500/20 text-indigo-400 rounded-lg text-xs"><%= employees.length %> employees</span>
                </div>
                
                <% if (employees.length === 0) { %>
                    <div class="text-center py-12">
                        <div class="w-20 h-20 bg-gray-800 rounded-full flex items-center justify-center mx-auto mb-4">
                            <i class="ri-user-line text-4xl text-gray-600"></i>
                        </div>
                        <p class="text-gray-400">No employees in this department yet.</p>
                        <a href="/employees/create" class="inline-flex items-center gap-2 mt-4 px-5 py-2.5 bg-gradient-to-r from-indigo-500 to-purple-600 text-white rounded-xl hover:from-indigo-600 hover:to-purple-700 transition-all text-sm">
                            <i class="ri-add-line"></i> Add Employee
                        </a>
                    </div>
                <% } else { %>
                    <div class="grid gap-3">
                        <% employees.forEach(function(emp) { %>
                        <div class="employee-card rounded-xl p-4 cursor-pointer transition-all">
                            <div class="flex items-center justify-between">
                                <div class="flex items-center gap-3">
                                    <div class="w-10 h-10 bg-gradient-to-br from-indigo-500/20 to-purple-500/20 rounded-xl flex items-center justify-center">
                                        <i class="ri-user-3-line text-indigo-400 text-lg"></i>
                                    </div>
                                    <div>
                                        <a href="/employees/<%= emp._id %>" class="font-medium text-white hover:text-indigo-400 transition">
                                            <%= emp.fullName %>
                                        </a>
                                        <p class="text-xs text-gray-400 mt-1"><%= emp.jobTitle %></p>
                                    </div>
                                </div>
                                <% if (emp.supervisor) { %>
                                    <div class="flex items-center gap-2 text-xs text-gray-500">
                                        <i class="ri-user-star-line"></i>
                                        <span>Reports to: <%= emp.supervisor.fullName %></span>
                                    </div>
                                <% } %>
                            </div>
                        </div>
                        <% }); %>
                    </div>
                <% } %>
            </div>
        </div>
    </main>
</body>
</html>