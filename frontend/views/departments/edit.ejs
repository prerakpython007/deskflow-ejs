<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Department | OfficeMS</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.3.0/fonts/remixicon.css" rel="stylesheet"/>
    <style>
        body {
            background: linear-gradient(135deg, #0f0f1e 0%, #1a1a2e 100%);
        }
        .glass-card {
            background: rgba(30, 30, 46, 0.7);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.08);
        }
        .input-modern {
            background: rgba(15, 15, 30, 0.6);
            border: 1px solid rgba(255, 255, 255, 0.08);
            transition: all 0.3s ease;
        }
        .input-modern:focus {
            border-color: rgba(99, 102, 241, 0.5);
            box-shadow: 0 0 0 2px rgba(99, 102, 241, 0.1);
            outline: none;
        }
    </style>
</head>
<body class="min-h-screen">
    <nav class="border-b border-gray-800 bg-black/30 backdrop-blur-md sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16">
                <div class="flex items-center">
                    <div class="flex items-center gap-2">
                        <div class="w-8 h-8 bg-gradient-to-br from-indigo-500 to-purple-600 rounded-lg flex items-center justify-center">
                            <i class="ri-building-line text-white text-sm"></i>
                        </div>
                        <h1 class="text-xl font-bold bg-gradient-to-r from-indigo-400 to-purple-400 bg-clip-text text-transparent">OfficeMS</h1>
                    </div>
                    <div class="hidden sm:flex sm:ml-10 space-x-1">
                        <a href="/departments" class="px-4 py-2 rounded-lg text-sm font-medium text-gray-400 hover:text-white hover:bg-white/5 transition-all">
                            <i class="ri-layout-grid-line mr-2"></i>Departments
                        </a>
                        <a href="/employees" class="px-4 py-2 rounded-lg text-sm font-medium text-gray-400 hover:text-white hover:bg-white/5 transition-all">
                            <i class="ri-team-line mr-2"></i>Employees
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </nav>
    
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <% if (locals.error) { %>
            <div class="bg-red-500/10 border border-red-500/20 rounded-xl p-4 mb-6 backdrop-blur-sm">
                <div class="flex items-center gap-3">
                    <i class="ri-error-warning-line text-red-400 text-xl"></i>
                    <p class="text-sm text-red-300"><%= error %></p>
                </div>
            </div>
        <% } %>
        
        <div class="max-w-2xl mx-auto">
            <div class="glass-card rounded-2xl overflow-hidden">
                <div class="px-6 py-5 border-b border-gray-800">
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 bg-gradient-to-br from-indigo-500 to-purple-600 rounded-xl flex items-center justify-center">
                            <i class="ri-edit-line text-white text-lg"></i>
                        </div>
                        <div>
                            <h2 class="text-xl font-semibold text-white">Edit Department</h2>
                            <p class="text-sm text-gray-400 mt-1">Update department information</p>
                        </div>
                    </div>
                </div>
                
                <form action="/departments/<%= department._id %>?_method=PUT" method="POST" class="p-6 space-y-5">
                    <div>
                        <label class="block text-sm font-medium text-gray-300 mb-2">Department Name <span class="text-red-400">*</span></label>
                        <input type="text" 
                               name="name" 
                               value="<%= department.name %>"
                               class="input-modern w-full px-4 py-2.5 rounded-xl text-white"
                               required>
                    </div>
                    
                    <div>
                        <label class="block text-sm font-medium text-gray-300 mb-2">Description</label>
                        <textarea name="description" 
                                  rows="4"
                                  class="input-modern w-full px-4 py-2.5 rounded-xl text-white resize-none"><%= department.description || '' %></textarea>
                    </div>
                    
                    <div class="flex justify-end gap-3 pt-4">
                        <a href="/departments" class="px-5 py-2.5 border border-gray-700 rounded-xl text-gray-300 hover:bg-white/5 transition-all">
                            Cancel
                        </a>
                        <button type="submit" class="px-5 py-2.5 bg-gradient-to-r from-indigo-500 to-purple-600 hover:from-indigo-600 hover:to-purple-700 text-white rounded-xl font-medium transition-all shadow-lg">
                            <i class="ri-save-line mr-2"></i>Update Department
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </main>
</body>
</html>