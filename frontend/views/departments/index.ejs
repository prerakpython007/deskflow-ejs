<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Departments | OfficeMS</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.3.0/fonts/remixicon.css" rel="stylesheet"/>
    <style>
        body {
            background: linear-gradient(135deg, #0f0f1e 0%, #1a1a2e 100%);
        }
        .glass-card {
            background: rgba(30, 30, 46, 0.7);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.08);
        }
        .hover-glow:hover {
            box-shadow: 0 0 20px rgba(99, 102, 241, 0.3);
            transition: all 0.3s ease;
        }
        .table-row {
            transition: all 0.2s ease;
        }
        .table-row:hover {
            background: rgba(99, 102, 241, 0.08);
        }
    </style>
</head>
<body class="min-h-screen">
    <nav class="border-b border-gray-800 bg-black/30 backdrop-blur-md sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16">
                <div class="flex items-center">
                    <div class="flex items-center gap-2">
                        <div class="w-8 h-8 bg-gradient-to-br from-indigo-500 to-purple-600 rounded-lg flex items-center justify-center">
                            <i class="ri-building-line text-white text-sm"></i>
                        </div>
                        <h1 class="text-xl font-bold bg-gradient-to-r from-indigo-400 to-purple-400 bg-clip-text text-transparent">OfficeMS</h1>
                    </div>
                    <div class="hidden sm:flex sm:ml-10 space-x-1">
                        <a href="/departments" class="px-4 py-2 rounded-lg text-sm font-medium bg-gradient-to-r from-indigo-500 to-purple-600 text-white transition-all">
                            <i class="ri-layout-grid-line mr-2"></i>Departments
                        </a>
                        <a href="/employees" class="px-4 py-2 rounded-lg text-sm font-medium text-gray-400 hover:text-white hover:bg-white/5 transition-all">
                            <i class="ri-team-line mr-2"></i>Employees
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </nav>
    
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <% if (locals.error) { %>
            <div class="bg-red-500/10 border border-red-500/20 rounded-xl p-4 mb-6 backdrop-blur-sm">
                <div class="flex items-center gap-3">
                    <i class="ri-error-warning-line text-red-400 text-xl"></i>
                    <p class="text-sm text-red-300"><%= error %></p>
                </div>
            </div>
        <% } %>
        
        <div class="glass-card rounded-2xl overflow-hidden hover-glow transition-all duration-300">
            <div class="px-6 py-5 border-b border-gray-800 flex justify-between items-center">
                <div>
                    <h2 class="text-xl font-semibold text-white">All Departments</h2>
                    <p class="text-sm text-gray-400 mt-1">Manage your organization departments</p>
                </div>
                <a href="/departments/create" class="bg-gradient-to-r from-indigo-500 to-purple-600 hover:from-indigo-600 hover:to-purple-700 text-white px-5 py-2.5 rounded-xl text-sm font-medium transition-all flex items-center gap-2 shadow-lg">
                    <i class="ri-add-line"></i> New Department
                </a>
            </div>
            
            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead>
                        <tr class="border-b border-gray-800">
                            <th class="px-6 py-4 text-left text-xs font-semibold text-gray-400 uppercase tracking-wider">Name</th>
                            <th class="px-6 py-4 text-left text-xs font-semibold text-gray-400 uppercase tracking-wider">Description</th>
                            <th class="px-6 py-4 text-left text-xs font-semibold text-gray-400 uppercase tracking-wider">Created</th>
                            <th class="px-6 py-4 text-right text-xs font-semibold text-gray-400 uppercase tracking-wider">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-800">
                        <% departments.forEach(function(dept) { %>
                        <tr class="table-row transition-all">
                            <td class="px-6 py-4 whitespace-nowrap">
                                <a href="/departments/<%= dept._id %>" class="text-indigo-400 hover:text-indigo-300 font-medium transition flex items-center gap-2">
                                    <i class="ri-folder-line text-indigo-400"></i>
                                    <%= dept.name %>
                                </a>
                            </td>
                            <td class="px-6 py-4">
                                <span class="text-gray-300 text-sm"><%= dept.description || '-' %></span>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-400">
                                <%= dept.createdAt.toLocaleDateString() %>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-right text-sm">
                                <a href="/departments/<%= dept._id %>/edit" class="text-indigo-400 hover:text-indigo-300 mr-4 transition inline-flex items-center gap-1">
                                    <i class="ri-edit-line"></i> Edit
                                </a>
                                <form action="/departments/<%= dept._id %>?_method=DELETE" method="POST" class="inline">
                                    <button type="submit" class="text-red-400 hover:text-red-300 transition inline-flex items-center gap-1" onclick="return confirm('Delete this department?')">
                                        <i class="ri-delete-bin-line"></i> Delete
                                    </button>
                                </form>
                            </td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        </div>
    </main>
</body>
</html>