<% title = 'Departments' %>
<% include ../layouts/main.ejs %>

<div class="bg-white rounded-lg shadow">
    <div class="flex justify-between items-center p-6 border-b">
        <h1 class="text-2xl font-bold">Departments</h1>
        <a href="/departments/create" class="bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700">
            + New Department
        </a>
    </div>
    
    <div class="overflow-x-auto">
        <table class="w-full">
            <thead class="bg-gray-50">
                <tr>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Name</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Description</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Created</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-200">
                <% departments.forEach(dept => { %>
                <tr class="hover:bg-gray-50">
                    <td class="px-6 py-4">
                        <a href="/departments/<%= dept._id %>" class="text-blue-600 hover:underline">
                            <%= dept.name %>
                        </a>
                    </td>
                    <td class="px-6 py-4"><%= dept.description || '-' %></td>
                    <td class="px-6 py-4"><%= dept.createdAt.toLocaleDateString() %></td>
                    <td class="px-6 py-4 space-x-2">
                        <a href="/departments/<%= dept._id %>/edit" class="text-blue-600 hover:text-blue-800">Edit</a>
                        <form action="/departments/<%= dept._id %>?_method=DELETE" method="POST" class="inline">
                            <button type="submit" class="text-red-600 hover:text-red-800" onclick="return confirm('Delete this department?')">Delete</button>
                        </form>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>