<% title = 'Create Department' %>
<% include ../layouts/main.ejs %>

<div class="max-w-2xl mx-auto bg-white rounded-lg shadow p-6">
    <h1 class="text-2xl font-bold mb-6">Create New Department</h1>
    
    <form action="/departments" method="POST">
        <div class="mb-4">
            <label class="block text-gray-700 font-medium mb-2">Department Name *</label>
            <input type="text" 
                   name="name" 
                   value="<%= department && department.name ? department.name : '' %>"
                   class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:border-blue-500"
                   required>
        </div>
        
        <div class="mb-4">
            <label class="block text-gray-700 font-medium mb-2">Description</label>
            <textarea name="description" 
                      rows="4"
                      class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:border-blue-500"><%= department && department.description ? department.description : '' %></textarea>
        </div>
        
        <div class="flex justify-end space-x-3">
            <a href="/departments" class="btn-secondary px-4 py-2 rounded-lg">Cancel</a>
            <button type="submit" class="btn-primary px-4 py-2 rounded-lg">Create Department</button>
        </div>
    </form>
</div>